rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - customApiKey: string
    //   - createdAt: timestamp
    //
    // Collection: content
    // Document ID: {contentId}
    // Fields:
    //   - uid: string (required)
    //   - type: string (required, enum: story, article, script, ad, affiliate)
    //   - title: string
    //   - content: string (required)
    //   - metadata: map
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('customApiKey' in data) || (data.customApiKey is string && data.customApiKey.size() < 200));
    }

    function isValidContent(data) {
      return data.keys().hasAll(['uid', 'type', 'content', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.type in ['story', 'article', 'script', 'ad', 'affiliate'] &&
             data.content is string &&
             data.content.size() < 1000000; // 1MB limit check
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "khoa47ai@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidContent(request.resource.data);
      allow update: if isDocOwner() && isValidContent(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
