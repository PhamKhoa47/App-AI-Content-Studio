{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "customApiKey": { "type": "string", "description": "Optional user-provided Gemini API key" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SavedContent": {
      "title": "Saved Content",
      "description": "Stores user generated stories, scripts, etc.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["story", "article", "script", "ad", "affiliate"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/content/{contentId}": {
      "schema": "SavedContent",
      "description": "User generated content"
    }
  }
}
